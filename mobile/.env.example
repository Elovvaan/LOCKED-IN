# Production Railway backend URL — used by EAS cloud builds automatically.
# EXPO_PUBLIC_ prefix makes this value available inside the app bundle at build time.
# For EAS builds, set this as an EAS secret (eas secret:create) or keep it here
# since it is already a public URL (no credentials embedded).
EXPO_PUBLIC_API_URL=https://locked-in-production.up.railway.app

# --- EAS Submit credentials (required only when running `eas submit`) ---
# Set these in your shell or via `eas secret:create` — do NOT commit real values.
# APPLE_ID=your-apple-id@example.com
# ASC_APP_ID=1234567890          # App Store Connect numeric app ID
# APPLE_TEAM_ID=XXXXXXXXXX       # 10-character Apple Developer Team ID
