# Set this to your deployed Railway backend URL (e.g. https://your-app.up.railway.app).
# For local development on a physical device, use your machine's LAN IP instead
# (e.g. http://192.168.1.x:3000). Do NOT use localhost — it won't reach the backend
# from a real device or Expo Go.
EXPO_PUBLIC_API_URL=https://your-app.up.railway.app
