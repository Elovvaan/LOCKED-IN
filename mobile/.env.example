# Production Railway backend URL — used by EAS cloud builds automatically.
# EXPO_PUBLIC_ prefix makes this value available inside the app bundle at build time.
EXPO_PUBLIC_API_URL=https://locked-in-production.up.railway.app

# Expo/EAS project configuration for production builds.
EXPO_OWNER=REPLACE_WITH_EXPO_USERNAME
EAS_PROJECT_ID=REPLACE_WITH_EAS_PROJECT_ID
ANDROID_PACKAGE=com.lockedin.app

# --- EAS Submit: Google Play (required for `eas submit --platform android`) ---
# Paste the full JSON contents of your Google Play service account key here.
# The prepare:google-play-key script writes it to ./google-play-service-account.json at submit time.
# GOOGLE_PLAY_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# --- iOS deferred — do not fill in yet ---
# IOS_BUNDLE_IDENTIFIER=com.lockedin.app
# APPLE_ID=your-apple-id@example.com
# ASC_APP_ID=1234567890
# APPLE_TEAM_ID=XXXXXXXXXX
