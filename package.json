{
  "name": "locked-in",
  "version": "1.0.0",
  "description": "REAL CHALLENGE GAME backend API",
  "main": "dist/index.js",
  "scripts": {
    "postinstall": "npm --prefix mobile ci",
    "build:backend": "tsc",
    "build:frontend": "npm --prefix mobile run build:web",
    "build": "npm run build:backend && npm run build:frontend",
    "prestart": "node -e \"const fs=require('fs'); const {execSync}=require('child_process'); if (!fs.existsSync('dist/index.js') || !fs.existsSync('mobile/dist/index.html')) { execSync('npm run build', { stdio: 'inherit' }); }\"",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "seed": "ts-node src/seed.ts",
    "test": "jest --forceExit"
  },
  "dependencies": {
    "@types/cors": "^2.8.19",
    "@types/express-rate-limit": "^5.1.3",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.6",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.2",
    "jsonwebtoken": "^9.0.0",
    "sequelize": "^6.32.1",
    "sqlite3": "^5.1.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.2",
    "@types/express": "^4.17.17",
    "@types/node": "^20.0.0",
    "@types/jest": "^29.5.3",
    "@types/jsonwebtoken": "^9.0.2",
    "@types/supertest": "^2.0.12",
    "jest": "^29.6.2",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.1.6"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.ts"
    ],
    "forceExit": true
  }
}
